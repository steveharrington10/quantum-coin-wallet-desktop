{
  "name": "quantumwallet",
  "productName": "quantumwallet",
  "version": "3.1.13",
  "description": "Quantum Coin",
  "main": "src/index.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder",
    "publish": "electron-builder --publish always",
    "lint": "eslint src",
    "build-icons": "node scripts/build-icons.js",
    "build-mac": "electron-builder --mac",
    "build-win": "electron-builder --win"
  },
  "author": "Quantum Coin Community",
  "license": "MIT",
  "dependencies": {
    "electron-squirrel-startup": "^1.0.0",
    "quantumcoin": "^7.0.9",
    "quantumswap": "^0.0.5",
    "sjcl": "^1.0.8"
  },
  "devDependencies": {
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9.0.0"
  },
  "engines": {
    "node": ">=24.14.1",
    "npm": ">=11.12.1"
  },
  "build": {
    "appId": "com.quantumcoin.wallet",
    "productName": "QuantumCoinWallet",
    "asar": true,
    "files": [
      "src/**",
      "js/**",
      "lib/**",
      "assets/**"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64", "ia32"]
        }
      ],
      "icon": "src/assets/icons/app/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": true
    },
    "mac": {
      "category": "public.app-category.finance",
      "target": [
        {
          "target": "dmg",
          "arch": ["x64","arm64"]
        }
      ],
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "icon": "build/icon-trans.icns"
    },
    "dmg": {
      "artifactName": "${productName}-${version}-${arch}.dmg",
      "icon": "build/icon-trans.icns",
      "sign": false
    },
    "publish": [
      {
        "provider": "github",
        "repo": "quantumswap-wallet-desktop",
        "releaseType": "release"
      }
    ]
  },
  "overrides": {
    "rimraf": "^5.0.5",
    "glob": "^13.0.6",
    "tar": "^7.0.0",
    "boolean": "^3.2.1"
  }
}
